<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/marks_background"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/marks_background"
        android:elevation="0dp"
        android:theme="@style/ThemeOverlay.Material3.ActionBar"
        app:navigationIconTint="@color/marks_text_primary"
        app:title="@string/portal_title"
        app:titleTextColor="@color/marks_text_primary" />

    <ProgressBar
        android:id="@+id/pageLoadProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:max="100"
        android:progressBackgroundTint="@color/marks_divider"
        android:progressTint="@color/marks_indicator"
        android:visibility="gone" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/marks_background">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/marks_background" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>

