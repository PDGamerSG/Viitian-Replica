<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardBackgroundColor="@color/marks_surface"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/marks_surface_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingTop="14dp"
        android:paddingEnd="18dp"
        android:paddingBottom="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/assessmentTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/marks_text_primary"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/assessmentLastDateText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/marks_text_primary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/assessmentStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/marks_grade_poor"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/assessmentActionsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="start|center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/downloadQuestionButton"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="0dp"
                    android:text="@string/da_action_download_qp"
                    android:textAllCaps="false"
                    app:iconTint="@color/marks_indicator" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/downloadDaButton"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:minHeight="0dp"
                    android:text="@string/da_action_download_da"
                    android:textAllCaps="false"
                    app:iconTint="@color/marks_indicator" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/uploadDaButton"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:minHeight="0dp"
                    android:text="@string/da_action_upload_da"
                    android:textAllCaps="false"
                    app:iconTint="@color/marks_indicator" />
            </LinearLayout>
        </LinearLayout>

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginStart="12dp"
            android:contentDescription="@string/da_assessment_open_details"
            android:src="@drawable/ic_da_chevron_right"
            android:tint="@color/marks_text_primary" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
